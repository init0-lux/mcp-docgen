{
  "name": "mcp-docgen",
  "version": "1.0.0",
  "description": "AI-powered documentation generator for codebases",
  "main": "dist/cli.js",
  "bin": {
    "mcp-docgen": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
