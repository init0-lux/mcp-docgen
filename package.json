    "@google/generative-ai": "^0.21.0",
    "chalk": "^4.1.2",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "js-yaml": "^4.1.0",
    "prompts": "^2.4.2",
    "simple-git": "^3.27.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^2.1.0"
